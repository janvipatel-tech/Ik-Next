    },
    "credibility": {
      "type": "component",
      "repeatable": false,
      "component": "sections.credibility"
    },
    "ikEdge": {
      "type": "component",
      "repeatable": false,
      "component": "sections.feature-list"
    },
    "testimonials": {
      "type": "component",
      "repeatable": false,
      "component": "sections.testimonials"
    },
    "audience": {
      "type": "component",
      "repeatable": false,
